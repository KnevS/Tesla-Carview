# ============================================================
# Tesla Carview – Konfiguration
# Kopieren nach .env und alle Werte befuellen
# ============================================================

# Server-Port (intern)
PORT=3000

# JWT-Secret – mindestens 64 zufaellige Zeichen
# Generieren: openssl rand -hex 64
JWT_SECRET=change-me-to-a-very-long-random-secret-min-64-chars

# Oeffentliche URL der Anwendung (ohne abschliessendem /)
# Beispiel: https://tesla.example.com  oder  http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Tesla Fleet API – Zugangsdaten aus dem Tesla Developer Portal
# https://developer.tesla.com/
TESLA_CLIENT_ID=your-client-id-here
TESLA_CLIENT_SECRET=your-client-secret-here
TESLA_REDIRECT_URI=${FRONTEND_URL}/api/auth/callback
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Datenbank-Pfad (wird automatisch angelegt)
DB_PATH=./data/tesla-carview.db

# Fahrzeugdaten-Poller deaktivieren: false
ENABLE_POLLER=true

# Web Push – Benachrichtigungen bei Ladeende (optional)
# Generieren: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:deine@email.de
