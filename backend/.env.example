# Server
PORT=3000
JWT_SECRET=change-me-to-a-random-secret

# Tesla Fleet API
TESLA_CLIENT_ID=your-client-id-here
TESLA_CLIENT_SECRET=your-client-secret-here
TESLA_REDIRECT_URI=https://tesla.iland.krische.com/api/auth/callback
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Datenbank
DB_PATH=./data/tesla-carview.db

# Frontend URL (für CORS)
FRONTEND_URL=https://tesla.iland.krische.com

# Poller (auf false setzen um automatisches Polling zu deaktivieren)
ENABLE_POLLER=true

# Web Push Benachrichtigungen (optional)
# Generieren mit: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
