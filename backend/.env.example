# ============================================================
# Tesla Carview – Konfiguration
# Kopieren nach .env und alle Werte befuellen
# ============================================================

# Server-Port (intern)
PORT=3000

# JWT-Secret – mindestens 64 zufaellige Zeichen
# Generieren: openssl rand -hex 64
JWT_SECRET=change-me-to-a-very-long-random-secret-min-64-chars

# Optionales Setup-Token-Gate fuer den /api/setup/init-Endpoint.
# Wenn gesetzt, muss der Initial-Setup-Request den Header
# X-Setup-Token: <wert> mitschicken. Verhindert, dass ein Angreifer
# den ersten Admin anlegt, wenn der Service vor dir online geht.
# Generieren: openssl rand -hex 32
# Leer lassen, wenn nicht benoetigt — Rate-Limit + atomare Check-then-
# Write Schutz greifen ohnehin.
# SETUP_TOKEN=

# Oeffentliche URL der Anwendung (ohne abschliessendem /)
# Beispiel: https://tesla.example.com  oder  http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Tesla Fleet API – Zugangsdaten aus dem Tesla Developer Portal
# https://developer.tesla.com/
TESLA_CLIENT_ID=your-client-id-here
TESLA_CLIENT_SECRET=your-client-secret-here
TESLA_REDIRECT_URI=${FRONTEND_URL}/api/auth/callback
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Datenbank-Pfad (wird automatisch angelegt)
DB_PATH=./data/tesla-carview.db

# Fahrzeugdaten-Poller deaktivieren: false
ENABLE_POLLER=true

# Web Push – Benachrichtigungen bei Ladeende (optional)
# Generieren: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:deine@email.de

# Tesla API Usage Tracker – Webhook für Tesla-Validierungs-Mails (optional)
# Wenn gesetzt: POST /api/tesla-usage/webhook/email mit Header
#   X-Webhook-Secret: <Wert>
# nimmt Tesla-Notification-Mails (z. B. von Microsoft Graph Subscriber) an.
TESLA_USAGE_WEBHOOK_SECRET=

# Demo-Sandbox (nur wenn DEMO_ENABLED=true)
# MAX_ACTIVE_DEMO_USERS  Gleichzeitig aktive Tester-Accounts  (Default: 200)
# DEMO_LIFETIME_DAYS     Lebenszeit pro Account in Tagen       (Default: 2)
# DEMO_SIGNUPS_PER_IP    Anmeldungen pro IP & 24 h             (Default: 2)
# MAX_ACTIVE_DEMO_USERS=200
# DEMO_LIFETIME_DAYS=2
# DEMO_SIGNUPS_PER_IP=2

# A Better Route Planner (ABRP) Integration – Live-Telemetrie (optional)
# App-API-Key: kostenlos registrieren unter https://api.iternio.com
# User-Token: in ABRP unter Profile → Live Data → "Connect" → Token anzeigen
# Ohne diesen Key bleibt ABRP inaktiv, auch wenn ein User-Token hinterlegt ist.
ABRP_API_KEY=
