# ============================================================
# Tesla Carview – Configuration
# Copy to .env and fill in all values
# ============================================================

# Internal server port
PORT=3000

# JWT secret – at least 64 random characters
# Generate: openssl rand -hex 64
JWT_SECRET=change-me-to-a-very-long-random-secret-min-64-chars

# Optional setup-token gate for the /api/setup/init endpoint.
# When set, the initial setup request must include the header
# X-Setup-Token: <value>. Prevents an attacker from creating the
# first admin if the service goes online before you do.
# Generate: openssl rand -hex 32
# Leave empty if not needed — rate-limit + atomic check-then-write
# protection applies regardless.
# SETUP_TOKEN=

# Public URL of the application (no trailing slash)
# Example: https://tesla.example.com  or  http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Tesla Fleet API – credentials from the Tesla Developer Portal
# https://developer.tesla.com/
TESLA_CLIENT_ID=your-client-id-here
TESLA_CLIENT_SECRET=your-client-secret-here
TESLA_REDIRECT_URI=${FRONTEND_URL}/api/auth/callback
TESLA_AUTH_BASE=https://auth.tesla.com/oauth2/v3
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Database path (created automatically)
DB_PATH=./data/tesla-carview.db

# Disable vehicle-data poller: false
ENABLE_POLLER=true

# Sleep monitor: how often the vehicle *list* endpoint is checked for the
# online/asleep state (minutes, min. 5). Cheap list call, does not wake the
# car and does not count against TESLA_DAILY_CAP / TESLA_MONTHLY_CAP.
TESLA_SLEEP_POLL_MINUTES=15

# Web Push – browser/Apple Watch notifications (optional)
# Generate keys once: docker exec <backend-container> npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:your@email.com

# Telegram Bot – push notifications + sentry alerts (optional)
# 1. Create a bot at https://t.me/BotFather → /newbot
# 2. Copy the token here
# 3. Webhook URL: set to your app's public URL (e.g. https://yourapp.example.com)
#    If not set, the bot runs in long-polling mode (also works, but less efficient)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Tesla API Usage Tracker – webhook for Tesla validation emails (optional)
# When set: POST /api/tesla-usage/webhook/email with header
#   X-Webhook-Secret: <value>
# receives Tesla notification emails (e.g. from a Microsoft Graph subscriber).
TESLA_USAGE_WEBHOOK_SECRET=

# Demo sandbox (only when DEMO_ENABLED=true)
# MAX_ACTIVE_DEMO_USERS  Concurrent active test accounts  (Default: 200)
# DEMO_LIFETIME_DAYS     Account lifetime in days         (Default: 2)
# DEMO_SIGNUPS_PER_IP    Sign-ups per IP per 24 h         (Default: 2)
# MAX_ACTIVE_DEMO_USERS=200
# DEMO_LIFETIME_DAYS=2
# DEMO_SIGNUPS_PER_IP=2

# A Better Route Planner (ABRP) integration – live telemetry (optional)
# App API key: register free at https://api.iternio.com
# User token: in ABRP under Profile → Live Data → "Connect" → show token
# Without this key ABRP stays inactive even if a user token is stored.
ABRP_API_KEY=

# OSM tile cache directory (optional). Default: <DATA_DIR>/tiles — persistent
# alongside the databases. Override to place the cache somewhere else.
TILE_CACHE_DIR=
