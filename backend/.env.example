# Server
PORT=3000

# WICHTIG: Zufaelligen Wert setzen, z.B.: openssl rand -hex 64
JWT_SECRET=change-me-to-a-very-long-random-secret-min-64-chars

# Tesla Fleet API
TESLA_CLIENT_ID=your-client-id-here
TESLA_CLIENT_SECRET=your-client-secret-here
TESLA_REDIRECT_URI=https://tesla.iland.krische.com/api/auth/callback
TESLA_AUDIENCE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Datenbank (im Docker-Volume)
DB_PATH=./data/tesla-carview.db

# Frontend-URL fuer CORS und Redirects
FRONTEND_URL=https://tesla.iland.krische.com

# Poller deaktivieren: ENABLE_POLLER=false
ENABLE_POLLER=true

# Web Push (optional, generieren mit: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
